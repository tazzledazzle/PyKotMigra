{
  "$defs": {
    "CliInfo": {
      "properties": {
        "version": {
          "title": "Version",
          "type": "string"
        },
        "argv": {
          "items": {
            "type": "string"
          },
          "title": "Argv",
          "type": "array"
        }
      },
      "required": [
        "version"
      ],
      "title": "CliInfo",
      "type": "object"
    },
    "ErrorItem": {
      "properties": {
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "hint": {
          "default": "",
          "title": "Hint",
          "type": "string"
        },
        "rule_id": {
          "default": "unknown",
          "title": "Rule Id",
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "title": "ErrorItem",
      "type": "object"
    },
    "FileRecord": {
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "bytes": {
          "title": "Bytes",
          "type": "integer"
        },
        "ast_ok": {
          "title": "Ast Ok",
          "type": "boolean"
        },
        "ast_error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ast Error"
        },
        "imports": {
          "items": {
            "type": "string"
          },
          "title": "Imports",
          "type": "array"
        },
        "libcst_ok": {
          "default": false,
          "title": "Libcst Ok",
          "type": "boolean"
        },
        "libcst_error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Libcst Error"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes",
        "ast_ok"
      ],
      "title": "FileRecord",
      "type": "object"
    },
    "GapItem": {
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "code": {
          "default": "",
          "title": "Code",
          "type": "string"
        }
      },
      "required": [
        "path",
        "message"
      ],
      "title": "GapItem",
      "type": "object"
    },
    "ImportEdge": {
      "properties": {
        "src": {
          "title": "Src",
          "type": "string"
        },
        "dst": {
          "title": "Dst",
          "type": "string"
        },
        "kind": {
          "default": "import",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "src",
        "dst"
      ],
      "title": "ImportEdge",
      "type": "object"
    },
    "MypySummary": {
      "properties": {
        "attempted": {
          "default": false,
          "title": "Attempted",
          "type": "boolean"
        },
        "exit_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Exit Code"
        },
        "stdout": {
          "default": "",
          "title": "Stdout",
          "type": "string"
        },
        "stderr": {
          "default": "",
          "title": "Stderr",
          "type": "string"
        },
        "hint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hint"
        }
      },
      "title": "MypySummary",
      "type": "object"
    }
  },
  "properties": {
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "generated_at": {
      "title": "Generated At",
      "type": "string"
    },
    "project_root": {
      "title": "Project Root",
      "type": "string"
    },
    "cli": {
      "$ref": "#/$defs/CliInfo"
    },
    "files": {
      "items": {
        "$ref": "#/$defs/FileRecord"
      },
      "title": "Files",
      "type": "array"
    },
    "import_graph": {
      "items": {
        "$ref": "#/$defs/ImportEdge"
      },
      "title": "Import Graph",
      "type": "array"
    },
    "openapi": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Openapi"
    },
    "gaps": {
      "items": {
        "$ref": "#/$defs/GapItem"
      },
      "title": "Gaps",
      "type": "array"
    },
    "errors": {
      "items": {
        "$ref": "#/$defs/ErrorItem"
      },
      "title": "Errors",
      "type": "array"
    },
    "mypy": {
      "anyOf": [
        {
          "$ref": "#/$defs/MypySummary"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "generated_at",
    "project_root",
    "cli"
  ],
  "title": "AnalysisRoot",
  "type": "object"
}